# ShieldAI — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Server ---
HOST=0.0.0.0
PORT=8000
RELOAD=false

# --- VirusTotal integration (optional) ---
# Leave blank to run in mock/demo mode (no real VT calls)
VT_API_KEY=9283742d8c7f03954d9ca870cc4e2f0a3eccf3e6062b2da69d1a8b6622bad498

# --- Security ---
# Comma-separated list of allowed origins for CORS.
# Use * only for local development.
ALLOWED_ORIGINS=*

# --- Rate limiting (requests per minute per IP) ---
RATE_LIMIT=60

